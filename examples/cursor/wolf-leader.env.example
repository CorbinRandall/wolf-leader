# Wolf Leader hub URLs — copied to ~/.cursor/wolf-leader.env by install-cursor-client.sh
# Edit after install if your hub moves.

WOLF_LEADER_API=http://YOUR_HOST:6971
WOLF_LEADER_MCP=http://YOUR_HOST:6972/mcp

# Optional: override when the hub runs on the same machine as Cursor SSH
# WOLF_LEADER_API_LOCAL=http://127.0.0.1:6971
