# Copy to .env and edit for your environment:
#   cp .env.example .env
#
# Wolf Leader — AI Project Storage
# Env vars use IDE_STORAGE_* prefix for backward compatibility with existing installs.

# --- Required: how clients reach the hub ---
# LAN IP, hostname, or Tailscale name — used in agent briefs and MCP setup docs.
IDE_STORAGE_PUBLIC_URL=http://192.168.1.100:6971
IDE_STORAGE_MCP_URL=http://192.168.1.100:6972/mcp

# Optional label inserted into pickup prompts ("Continue Foo on myserver …")
IDE_STORAGE_HOST_LABEL=myserver

# --- Paths (container defaults work for portable installs) ---
IDE_STORAGE_DB_PATH=/data/ide-work.db
IDE_STORAGE_DB_PATH_HOST=./data/ide-work.db
IDE_STORAGE_PROJECTS_DIR=/data/projects
IDE_STORAGE_COMPOSE_PATH=/app
IDE_STORAGE_CONTAINER=wolf-leader

# --- Cursor transcript import (optional) ---
# Host path mounted into the container; leave empty to skip auto-import.
# CURSOR_TRANSCRIPTS_ROOT=/home/you/.cursor/projects/your-workspace/agent-transcripts

# --- Compose auto-discovery (optional) ---
# If set, Wolf Leader scans this folder for docker-compose.yml stacks to register as projects.
# COMPOSE_MANAGER_ROOT=/path/to/compose/projects

# --- Service ports ---
PORT=6971
MCP_PORT=6972
HOST=0.0.0.0
MCP_HOST=0.0.0.0
LOG_LEVEL=info
